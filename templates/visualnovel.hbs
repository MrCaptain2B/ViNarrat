<div class="vn-root">

  {{#if bg}}
  <div class="vn-bg" style="background-image: url({{bg}}); filter: brightness({{bgBrightness}});"></div>
  {{else}}
  <div class="vn-bg vn-bg-default" style="filter: brightness({{bgBrightness}});"></div>
  {{/if}}

  {{#if showPanel}}
  {{!-- ─────────── PANELS ─────────── --}}
  <div class="vn-content">

  {{#if (eq showPanel "locations")}}
  <div class="vn-panel">
    <div class="vn-panel-header">
      <span class="vn-panel-title">Locations</span>
      <button class="vn-loc-back"><i class="fas fa-arrow-left"></i> Back</button>
    </div>
    <div class="vn-filter-row">
      <input class="vn-loc-search" type="text" placeholder="Search locations...">
      <select class="vn-loc-group-filter">
        <option value="">All groups</option>
        {{#each locGroups}}
        <option value="{{this}}">{{this}}</option>
        {{/each}}
      </select>
    </div>
    <div class="vn-loc-list">
      {{#each locations}}
      <div class="vn-loc-item" data-search="{{this.name}} {{this.tags}} {{this.group}}">
        <div class="vn-loc-info">
          <strong>{{this.name}}</strong>
          {{#if this.group}}<span class="vn-item-group">{{this.group}}</span>{{/if}}
          {{#if this.tags.length}}<span class="vn-loc-tags">{{this.tags}}</span>{{/if}}
        </div>
        <div class="vn-loc-actions">
          <button class="vn-loc-select" data-id="{{this.id}}">Set Background</button>
          <button class="vn-loc-delete" data-id="{{this.id}}" title="Delete"><i class="fas fa-trash"></i></button>
        </div>
      </div>
      {{/each}}
    </div>
    <div class="vn-loc-form">
      <div class="vn-form-row">
        <input class="vn-loc-f-name" type="text" placeholder="Location name">
        <input class="vn-loc-f-group" type="text" placeholder="Group (optional)">
      </div>
      <div class="vn-form-row">
        <input class="vn-loc-f-bg" type="text" placeholder="Background image path">
        <button class="vn-loc-fp" type="button"><i class="fas fa-folder-open"></i></button>
      </div>
      <input class="vn-loc-f-tags" type="text" placeholder="Tags (comma separated)">
      <input class="vn-loc-f-parent" type="text" placeholder="Parent location">
      <input class="vn-loc-f-weather" type="text" placeholder="Weather">
      <button class="vn-loc-save">Save Location</button>
    </div>
  </div>
  {{/if}}

  {{#if (eq showPanel "portraits")}}
  <div class="vn-panel">
    <div class="vn-panel-header">
      <span class="vn-panel-title">Portraits</span>
      <button class="vn-port-back"><i class="fas fa-arrow-left"></i> Back</button>
    </div>
    <div class="vn-filter-row">
      <input class="vn-port-search" type="text" placeholder="Search portraits...">
      <select class="vn-port-group-filter">
        <option value="">All groups</option>
        {{#each portGroups}}
        <option value="{{this}}">{{this}}</option>
        {{/each}}
      </select>
    </div>
    <div class="vn-port-list">
      {{#each allPortraits}}
      <div class="vn-port-item" data-search="{{this.name}} {{this.title}} {{this.group}}">
        <div class="vn-port-avatar">
          {{#if this.image}}<img src="{{this.image}}">{{/if}}
        </div>
        <div class="vn-port-info">
          <strong>{{this.name}}</strong>
          {{#if this.group}}<span class="vn-item-group">{{this.group}}</span>{{/if}}
          {{#if this.title}}<span class="vn-port-title">{{this.title}}</span>{{/if}}
        </div>
        <button class="vn-port-add-to-stage" data-id="{{this.id}}">Add to Stage</button>
        <button class="vn-port-delete" data-id="{{this.id}}" title="Delete"><i class="fas fa-trash"></i></button>
      </div>
      {{/each}}
    </div>
    <button class="vn-port-import">Import from Actors</button>
    <div class="vn-port-form">
      <div class="vn-form-row">
        <input class="vn-port-f-name" type="text" placeholder="Portrait name">
        <input class="vn-port-f-group" type="text" placeholder="Group (optional)">
      </div>
      <input class="vn-port-f-title" type="text" placeholder="Title (optional)">
      <div class="vn-form-row">
        <input class="vn-port-f-img" type="text" placeholder="Image path">
        <button class="vn-port-fp" type="button"><i class="fas fa-folder-open"></i></button>
      </div>
      <input class="vn-port-f-actor" type="text" placeholder="Actor ID (optional)">
      <button class="vn-port-save">Save Portrait</button>
    </div>
  </div>
  {{/if}}

  {{#if (eq showPanel "scene")}}
  <div class="vn-panel vn-panel-scene">
    <div class="vn-panel-header">
      <span class="vn-panel-title">Scene Settings</span>
      <button class="vn-scene-back"><i class="fas fa-arrow-left"></i> Back</button>
    </div>
    <div class="vn-scene-section">
      <label>Background Brightness</label>
      <input class="vn-scene-brightness" type="range" min="0.2" max="2" step="0.05" value="{{bgBrightness}}">
    </div>
    <div class="vn-scene-section">
      <label>Dialogue Box</label>
      <div class="vn-dialog-setting">
        <span>Width</span>
        <input class="vn-dialog-width" type="range" min="30" max="100" step="1" value="{{dialog.width}}">
        <span class="vn-dialog-val">{{dialog.width}}%</span>
      </div>
      <div class="vn-dialog-setting">
        <span>Height</span>
        <input class="vn-dialog-height" type="range" min="80" max="350" step="5" value="{{dialog.height}}">
        <span class="vn-dialog-val">{{dialog.height}}px</span>
      </div>
      <div class="vn-dialog-setting">
        <span>Opacity</span>
        <input class="vn-dialog-opacity" type="range" min="0.2" max="1" step="0.05" value="{{dialog.opacity}}">
        <span class="vn-dialog-val">{{dialog.opacity}}</span>
      </div>
      <div class="vn-dialog-setting">
        <span>Align</span>
        <div class="vn-dialog-align-group">
          <button class="vn-dialog-align {{#if (eq dialog.align 'left')}}vn-align-active{{/if}}" data-align="left">Left</button>
          <button class="vn-dialog-align {{#if (eq dialog.align 'center')}}vn-align-active{{/if}}" data-align="center">Center</button>
          <button class="vn-dialog-align {{#if (eq dialog.align 'right')}}vn-align-active{{/if}}" data-align="right">Right</button>
        </div>
      </div>
      <div class="vn-dialog-setting">
        <span>Text</span>
        <textarea class="vn-dialog-text" rows="3" placeholder="Type dialogue here...">{{dialog.text}}</textarea>
      </div>
    </div>
  </div>
  {{/if}}

  {{#if (eq showPanel "presets")}}
  <div class="vn-panel">
    <div class="vn-panel-header">
      <span class="vn-panel-title">Scene Presets</span>
      <button class="vn-presets-back"><i class="fas fa-arrow-left"></i> Back</button>
    </div>
    <div class="vn-presets-save-row">
      <input class="vn-presets-name-input" type="text" placeholder="Preset name">
      <button class="vn-presets-save-btn">Save Current</button>
    </div>
    <div class="vn-presets-list">
      {{#each presets}}
      <div class="vn-presets-row">
        <span>{{this.name}}</span>
        <div class="vn-presets-actions">
          <button class="vn-presets-load" data-id="{{this.id}}">Load</button>
          <button class="vn-presets-delete" data-id="{{this.id}}"><i class="fas fa-trash"></i></button>
        </div>
      </div>
      {{/each}}
    </div>
  </div>
  {{/if}}

  </div>{{!-- /vn-content --}}

  {{else}}
  {{!-- ─────────── MAIN STAGE ─────────── --}}
  <div class="vn-content">

  {{#unless hideUI}}
  <div class="vn-stage-area">
    {{#each portraits}}
    <div class="vn-portrait {{#if this.locked}}vn-portrait-locked{{/if}} {{#if this.selected}}vn-selected{{/if}}" data-port-idx="{{@index}}"
         style="left: {{this.x}}px; top: {{this.y}}px;
                transform: scale({{this.scale}}) {{#if this.flip}}scaleX(-1){{/if}};
                z-index: {{@index}};">
      <div class="vn-portrait-frame {{#unless this.speaking}}vn-dimmed{{/unless}}">
        {{#if this.image}}
        <img class="vn-portrait-img" src="{{this.image}}" alt="{{this.name}}">
        {{else}}
        <div class="vn-portrait-placeholder">{{this.name}}</div>
        {{/if}}
      </div>
    </div>
    {{/each}}
  </div>

  {{#if speaker}}
  <div class="vn-speaker-indicator">
    <span class="vn-speaker-name">{{speaker}}</span>
  </div>
  {{/if}}

  {{#if selectedPortrait}}
  <div class="vn-portrait-controls">
    <span class="vn-controls-name">{{selectedPortrait.name}}</span>
    <input class="vn-port-scale-inline" type="range" min="0.3" max="3" step="0.1" value="{{selectedPortrait.scale}}" data-port-idx="{{selectedPortrait.index}}">
    <button class="vn-port-bring-forward" data-port-idx="{{selectedPortrait.index}}" title="Bring Forward"><i class="fas fa-chevron-up"></i></button>
    <button class="vn-port-send-backward" data-port-idx="{{selectedPortrait.index}}" title="Send Backward"><i class="fas fa-chevron-down"></i></button>
    <button class="vn-port-lock {{#if selectedPortrait.locked}}vn-locked{{/if}}" data-port-idx="{{selectedPortrait.index}}" title="{{#if selectedPortrait.locked}}Unlock{{else}}Lock{{/if}}">
      <i class="fas {{#if selectedPortrait.locked}}fa-lock{{else}}fa-unlock{{/if}}"></i>
    </button>
    <button class="vn-port-remove" data-port-idx="{{selectedPortrait.index}}" title="Remove"><i class="fas fa-times"></i></button>
  </div>
  {{/if}}

  {{#if dialog.text}}
  <div class="vn-dialog-box" style="width: {{dialog.width}}%; height: {{dialog.height}}px; opacity: {{dialog.opacity}}; text-align: {{dialog.align}};">
    {{#if speaker}}
    <div class="vn-dialog-speaker">{{speaker}}</div>
    {{/if}}
    <div class="vn-dialog-content">{{dialog.text}}</div>
  </div>
  {{/if}}

  {{/unless}}

  {{!-- Requests queue (managers only) --}}
  {{#if canManage}}
  {{#if requests.length}}
  <div class="vn-requests">
    {{#each requests}}
    <div class="vn-request vn-request-{{this.priority}}">
      <span class="vn-request-text">{{this.playerName}}: {{this.text}}</span>
      <button class="vn-request-resolve" data-id="{{this.id}}"><i class="fas fa-check"></i></button>
    </div>
    {{/each}}
  </div>
  {{/if}}
  {{/if}}

  {{!-- Speaker Selector (managers only) --}}
  {{#if canManage}}
  {{#if portraits.length}}
  <div class="vn-speaker-bar">
    {{#each portraits}}
    <button class="vn-speaker-btn {{#if this.speaking}}vn-speaker-active{{/if}}" data-id="{{this.id}}">
      {{this.name}}
    </button>
    {{/each}}
  </div>
  {{/if}}
  {{/if}}

  {{!-- Manager Toolbar --}}
  {{#if canManage}}
  <div class="vn-gm-toolbar">
    <button class="vn-btn-locations" title="Locations"><i class="fas fa-map-marked-alt"></i></button>
    <button class="vn-btn-portraits" title="Portraits"><i class="fas fa-users"></i></button>
    <button class="vn-btn-scene" title="Scene Control"><i class="fas fa-sliders-h"></i></button>
    <button class="vn-btn-presets" title="Scene Presets"><i class="fas fa-bookmark"></i></button>
    {{! <button class="vn-btn-save-preset" title="Quick Save Preset"><i class="fas fa-save"></i></button> }}
    <button class="vn-btn-toggle-bg" title="Toggle Background"><i class="fas fa-image"></i></button>
    <button class="vn-btn-toggle-ui" title="Toggle UI"><i class="fas fa-eye-slash"></i></button>
    <button class="vn-btn-broadcast {{#if broadcasting}}vn-broadcast-active{{/if}}" title="{{#if broadcasting}}Stop{{else}}Start{{/if}} Broadcast">
      <i class="fas {{#if broadcasting}}fa-stop-circle{{else}}fa-play-circle{{/if}}"></i>
    </button>
    <button class="vn-btn-close" title="Close"><i class="fas fa-times"></i></button>
  </div>
  {{else}}
  <div class="vn-gm-toolbar vn-player-bar">
    <span class="vn-player-label">Free Visual Dialogs</span>
    <button class="vn-btn-close" title="Close"><i class="fas fa-times"></i></button>
  </div>
  {{/if}}

  </div>{{!-- /vn-content --}}
  {{/if}}

</div>
