<div class="vn-root">

  {{#if bg}}
  <div class="vn-bg" style="background-image: url({{bg}}); filter: brightness({{bgBrightness}});"></div>
  {{else}}
  <div class="vn-bg vn-bg-default" style="filter: brightness({{bgBrightness}});"></div>
  {{/if}}

  {{!-- ─────────── MAIN STAGE ─────────── --}}
  <div class="vn-content">

  {{#unless hideUI}}
  <div class="vn-stage-area">
    {{#each portraits}}
    <div class="vn-portrait {{#if this.locked}}vn-portrait-locked{{/if}} {{#if this.selected}}vn-selected{{/if}} {{#if this.isClaimed}}vn-claimed{{/if}}" data-port-idx="{{@index}}"
         style="left: {{this.x}}px; top: {{this.y}}px;
                transform: scale({{this.scale}}) {{#if this.flip}}scaleX(-1){{/if}};
                z-index: {{@index}};">
      <div class="vn-portrait-wrapper">
        {{#if this.hasEmotions}}
        {{#if (or this.selected this.isMyPortrait)}}
        <div class="vn-emotion-strip">
          {{#each this.images}}
          <button class="vn-emotion-thumb {{#if (eq @index ../this.emotionIdx)}}vn-emotion-active{{/if}}" data-port-idx="{{../this.index}}" data-emotion="{{@index}}">
            <img src="{{this}}" alt="">
          </button>
          {{/each}}
        </div>
        {{/if}}
        {{/if}}
        <div class="vn-portrait-frame {{#unless this.speaking}}vn-dimmed{{/unless}}">
          {{#if this.currentImg}}
          <img class="vn-portrait-img" src="{{this.currentImg}}" alt="{{this.name}}">
          {{else}}
          <div class="vn-portrait-placeholder">{{this.name}}</div>
          {{/if}}
        </div>
        {{#if this.isMyPortrait}}
        <button class="vn-attention-btn {{#if this.isClaimed}}vn-attention-active{{/if}}" data-port-idx="{{this.index}}" title="Attention">{{#if this.isClaimed}}<i class="fas fa-check-circle"></i>{{else}}<i class="fas fa-hand-paper"></i>{{/if}}</button>
        {{/if}}
        {{#if canManage}}
        {{#if this.isClaimed}}
        <button class="vn-approve-btn" data-port-idx="{{this.index}}" title="Approve as speaker"><i class="fas fa-check"></i></button>
        {{/if}}
        {{/if}}
      </div>
    </div>
    {{/each}}
  </div>

  {{#if dialog.showSpeaker}}
  {{#if speaker}}
  <div class="vn-speaker-indicator">
    <span class="vn-speaker-name" style="font-size: {{speakerFontSize}}px;">{{speaker}}</span>
  </div>
  {{/if}}
  {{/if}}

  {{#if selectedPortrait}}
  {{#if isGM}}
  <div class="vn-portrait-controls">
    <span class="vn-controls-name">{{selectedPortrait.name}}</span>
    <input class="vn-port-scale-inline" type="range" min="0.3" max="3" step="0.1" value="{{selectedPortrait.scale}}" data-port-idx="{{selectedPortrait.index}}">
    <button class="vn-port-bring-forward" data-port-idx="{{selectedPortrait.index}}" title="Bring Forward"><i class="fas fa-chevron-up"></i></button>
    <button class="vn-port-send-backward" data-port-idx="{{selectedPortrait.index}}" title="Send Backward"><i class="fas fa-chevron-down"></i></button>
    <button class="vn-port-flip" data-port-idx="{{selectedPortrait.index}}" title="Flip horizontally"><i class="fas fa-arrows-alt-h"></i></button>
    <button class="vn-port-lock {{#if selectedPortrait.locked}}vn-locked{{/if}}" data-port-idx="{{selectedPortrait.index}}" title="{{#if selectedPortrait.locked}}Unlock{{else}}Lock{{/if}}">
      <i class="fas {{#if selectedPortrait.locked}}fa-lock{{else}}fa-unlock{{/if}}"></i>
    </button>
    <button class="vn-port-remove" data-port-idx="{{selectedPortrait.index}}" title="Remove"><i class="fas fa-times"></i></button>
  </div>
  {{/if}}
  {{/if}}

  {{#if dialogEnabled}}
  {{#if (eq dialog.mode 2)}}
  <div class="vn-dialog-dual" style="bottom: {{dialog.yOffset}}px;">
    <div class="vn-dialog-box vn-dialog-left" style="height: {{dialog.height}}px; opacity: {{dialog.opacity}}; font-size: {{dialog.fontSize}}px;">
      {{#if dialog.showSpeaker}}{{#if speaker}}<div class="vn-dialog-speaker">{{speaker}}</div>{{/if}}{{/if}}
      <div class="vn-dialog-content" data-side="left">{{dialog.leftText}}</div>
    </div>
    <div class="vn-dialog-box vn-dialog-right" style="height: {{dialog.height}}px; opacity: {{dialog.opacity}}; font-size: {{dialog.fontSize}}px;">
      {{#if dialog.showSpeaker}}{{#if speaker}}<div class="vn-dialog-speaker">{{speaker}}</div>{{/if}}{{/if}}
      <div class="vn-dialog-content" data-side="right">{{dialog.text}}</div>
    </div>
  </div>
  {{else}}
  <div class="vn-dialog-box" style="width: {{dialog.width}}%; height: {{dialog.height}}px; opacity: {{dialog.opacity}}; text-align: {{dialog.align}}; font-size: {{dialog.fontSize}}px; bottom: {{dialog.yOffset}}px;">
    {{#if dialog.showSpeaker}}{{#if speaker}}<div class="vn-dialog-speaker">{{speaker}}</div>{{/if}}{{/if}}
    <div class="vn-dialog-content" data-side="single">{{dialog.text}}</div>
  </div>
  {{/if}}
  {{/if}}

  {{/unless}}

  {{!-- Requests queue (managers only) --}}
  {{#if canManage}}
  {{#if requests.length}}
  <div class="vn-requests">
    {{#each requests}}
    <div class="vn-request vn-request-{{this.priority}}">
      <span class="vn-request-text">{{this.playerName}}: {{this.text}}</span>
      <button class="vn-request-resolve" data-id="{{this.id}}"><i class="fas fa-check"></i></button>
    </div>
    {{/each}}
  </div>
  {{/if}}
  {{/if}}

  {{!-- Speaker Selector (managers only) --}}
  {{#if canManage}}
  {{#if portraits.length}}
  <div class="vn-speaker-bar">
    {{#each portraits}}
    <button class="vn-speaker-btn {{#if this.speaking}}vn-speaker-active{{/if}} {{#if this.isClaimed}}vn-speaker-claimed{{/if}}" data-id="{{this.id}}">
      {{this.name}}
    </button>
    {{/each}}
  </div>
  {{/if}}

  {{!-- Toolbar --}}
  <div class="vn-gm-toolbar">
    <button class="vn-btn-locations" title="Locations"><i class="fas fa-map-marked-alt"></i></button>
    <button class="vn-btn-portraits" title="Portraits"><i class="fas fa-users"></i></button>
    <button class="vn-btn-scene" title="Scene Control"><i class="fas fa-sliders-h"></i></button>
    <button class="vn-btn-presets" title="Scene Presets"><i class="fas fa-bookmark"></i></button>
    <button class="vn-btn-toggle-bg" title="Toggle Background"><i class="fas fa-image"></i></button>
    <button class="vn-btn-toggle-ui" title="Toggle UI"><i class="fas fa-eye-slash"></i></button>
    <div class="vn-broadcast-wrapper">
      <button class="vn-btn-broadcast {{#if broadcasting}}vn-broadcast-active{{/if}}" title="{{#if broadcasting}}Stop{{else}}Start{{/if}} Broadcast">
        <i class="fas {{#if broadcasting}}fa-stop-circle{{else}}fa-play-circle{{/if}}"></i>
      </button>
      <button class="vn-broadcast-toggle" title="Broadcast mode"><i class="fas fa-caret-down"></i></button>
      {{#if showBroadcastMenu}}
      <div class="vn-broadcast-menu">
        <button class="vn-broadcast-option {{#if (eq inviteMode 'all')}}vn-broadcast-option-active{{/if}}" data-mode="all">{{#if (eq inviteMode 'all')}}<i class="fas fa-check"></i> {{/if}}All Online</button>
        <button class="vn-broadcast-option {{#if (eq inviteMode 'stage')}}vn-broadcast-option-active{{/if}}" data-mode="stage">{{#if (eq inviteMode 'stage')}}<i class="fas fa-check"></i> {{/if}}Stage Only</button>
      </div>
      {{/if}}
    </div>
    <button class="vn-btn-close" title="Close"><i class="fas fa-times"></i></button>
  </div>
  {{else}}
  <div class="vn-gm-toolbar vn-player-bar">
    <span class="vn-player-label">Free Visual Dialogs</span>
    <button class="vn-btn-portraits" title="Portraits"><i class="fas fa-users"></i></button>
    <button class="vn-btn-close" title="Close"><i class="fas fa-times"></i></button>
  </div>
  {{/if}}
  </div>

  {{!-- ─────────── FLOATING PANELS ─────────── --}}
  {{#if showPanel}}
  <div class="vn-panel-overlay">
  {{#if (eq showPanel "locations")}}
  <div class="vn-panel-floating">
    <div class="vn-panel-header">
      <span class="vn-panel-title">Locations</span>
      <button class="vn-loc-back"><i class="fas fa-arrow-left"></i> Back</button>
    </div>
    <div class="vn-filter-row">
      <input class="vn-loc-search" type="text" placeholder="Search..." value="{{locSearchValue}}">
      <input class="vn-loc-tag-filter" type="text" placeholder="Filter by tag..." value="{{locTagSearchValue}}">
      <select class="vn-loc-group-filter">
        <option value="">All groups</option>
        {{#each locGroups}}
        <option value="{{this}}">{{this}}</option>
        {{/each}}
      </select>
    </div>
    <div class="vn-list-count">{{locations.length}} of {{locTotal}}</div>
    <div class="vn-loc-list">
      {{#each locations}}
      <div class="vn-loc-item" data-name="{{this.name}}" data-tags="{{this.tags}}" data-group="{{this.group}}">
        <div class="vn-loc-thumb"{{#if this.background}} style="background-image: url({{this.background}})"{{/if}}></div>
        <div class="vn-loc-info">
          <strong>{{this.name}}</strong>
          {{#if this.group}}<span class="vn-item-group">{{this.group}}</span>{{/if}}
          {{#if this.tags.length}}<span class="vn-loc-tags">{{this.tags}}</span>{{/if}}
        </div>
        <div class="vn-loc-actions">
          <button class="vn-loc-select" data-id="{{this.id}}">Set Background</button>
          <button class="vn-loc-edit" data-id="{{this.id}}" title="Edit"><i class="fas fa-pen"></i></button>
          <button class="vn-loc-delete" data-id="{{this.id}}" title="Delete"><i class="fas fa-trash"></i></button>
        </div>
      </div>
      {{/each}}
    </div>
    {{#if locRemaining}}<button class="vn-loc-show-more vn-show-more">Show {{locRemaining}} more</button>{{/if}}
    <div class="vn-loc-form">
      <div class="vn-form-row">
        <input class="vn-loc-f-name" type="text" placeholder="Location name">
        <input class="vn-loc-f-group" type="text" placeholder="Group (optional)">
      </div>
      <div class="vn-form-row">
        <input class="vn-loc-f-bg" type="text" placeholder="Background image path">
        <button class="vn-loc-fp" type="button"><i class="fas fa-folder-open"></i></button>
      </div>
      <input class="vn-loc-f-tags" type="text" placeholder="Tags (comma separated)">
      <input class="vn-loc-f-parent" type="text" placeholder="Parent location">
      <input class="vn-loc-f-weather" type="text" placeholder="Weather">
      <button class="vn-loc-save">{{#if editingLocId}}Update{{else}}Save{{/if}} Location</button>
    </div>
  </div>
  {{/if}}

  {{#if (eq showPanel "portraits")}}
  <div class="vn-panel-floating">
    <div class="vn-panel-header">
      <span class="vn-panel-title">Portraits</span>
      <button class="vn-port-back"><i class="fas fa-arrow-left"></i> Back</button>
    </div>
    <div class="vn-filter-row">
      <input class="vn-port-search" type="text" placeholder="Search..." value="{{portSearchValue}}">
      <input class="vn-port-tag-filter" type="text" placeholder="Filter by tag..." value="{{portTagSearchValue}}">
      <select class="vn-port-group-filter">
        <option value="">All groups</option>
        {{#each portGroups}}
        <option value="{{this}}">{{this}}</option>
        {{/each}}
      </select>
    </div>
    <div class="vn-list-count">{{allPortraits.length}} of {{portTotal}}</div>
    <div class="vn-port-list">
      {{#each allPortraits}}
      <div class="vn-port-item" data-name="{{this.name}}" data-title="{{this.title}}" data-tags="{{this.tags}}" data-group="{{this.group}}">
        <div class="vn-port-avatar">
          {{#if this.image}}<img src="{{this.image}}" loading="lazy">{{/if}}
        </div>
        <div class="vn-port-info">
          <strong>{{this.name}}</strong>
          {{#if this.group}}<span class="vn-item-group">{{this.group}}</span>{{/if}}
          {{#if this.title}}<span class="vn-port-title">{{this.title}}</span>{{/if}}
          {{#if this.tags.length}}<span class="vn-port-tags">{{this.tags}}</span>{{/if}}
        </div>
        {{#if ../canManage}}
        <button class="vn-port-add-to-stage" data-id="{{this.id}}">Add to Stage</button>
        {{/if}}
        <button class="vn-port-edit" data-id="{{this.id}}" title="Edit"><i class="fas fa-pen"></i></button>
        {{#if ../canManage}}
        <button class="vn-port-delete" data-id="{{this.id}}" title="Delete"><i class="fas fa-trash"></i></button>
        {{/if}}
      </div>
      {{/each}}
    </div>
    {{#if portRemaining}}<button class="vn-port-show-more vn-show-more">Show {{portRemaining}} more</button>{{/if}}
    {{#if canManage}}<button class="vn-port-import">Import from Actors</button>{{/if}}
    <div class="vn-port-form">
      <div class="vn-form-row">
        <input class="vn-port-f-name" type="text" placeholder="Portrait name">
        <input class="vn-port-f-group" type="text" placeholder="Group (optional)">
      </div>
      <div class="vn-form-row">
        <input class="vn-port-f-title" type="text" placeholder="Title (optional)">
        <input class="vn-port-f-tags" type="text" placeholder="Tags (comma separated)">
      </div>
      <div class="vn-form-row">
        <input class="vn-port-f-img" type="text" placeholder="Default image path">
        <button class="vn-port-fp" type="button"><i class="fas fa-folder-open"></i></button>
      </div>
      <div class="vn-port-emotions">
        <label>Emotions (alternate images)</label>
        <div class="vn-emotion-list"></div>
        <button class="vn-emotion-add" type="button"><i class="fas fa-plus"></i> Add emotion</button>
        <template class="vn-emotion-row-tpl">
          <div class="vn-emotion-row">
            <span class="vn-emotion-idx"></span>
            <input class="vn-emotion-path" type="text" placeholder="Emotion image path">
            <button class="vn-emotion-fp" type="button" title="Browse"><i class="fas fa-folder-open"></i></button>
            <button class="vn-emotion-remove" type="button" title="Remove"><i class="fas fa-times"></i></button>
          </div>
        </template>
      </div>
      <input class="vn-port-f-actor" type="text" placeholder="Actor ID (optional)">
      {{#if canManage}}
      <div class="vn-form-row">
        <span>Player</span>
        <select class="vn-port-f-user">
          <option value="">— None —</option>
          {{#each users}}
          <option value="{{this.id}}">{{this.name}}</option>
          {{/each}}
        </select>
      </div>
      {{/if}}
      <button class="vn-port-save">{{#if editingPortId}}Update{{else}}Save{{/if}} Portrait</button>
    </div>
  </div>
  {{/if}}

  {{#if (eq showPanel "scene")}}
  <div class="vn-panel-floating vn-panel-scene">
    <div class="vn-panel-header">
      <span class="vn-panel-title">Scene Settings</span>
      <button class="vn-scene-back"><i class="fas fa-arrow-left"></i> Back</button>
    </div>
    <div class="vn-scene-section">
      <label>Background Brightness</label>
      <input class="vn-scene-brightness" type="range" min="0.2" max="2" step="0.05" value="{{bgBrightness}}">
    </div>
    <div class="vn-scene-section">
      <label>Theme Colors</label>
      <div class="vn-dialog-setting">
        <span>Background</span>
        <input class="vn-theme-bg" type="color" value="{{themeBg}}">
      </div>
      <div class="vn-dialog-setting">
        <span>Accent</span>
        <input class="vn-theme-accent" type="color" value="{{themeAccent}}">
      </div>
    </div>
    <div class="vn-scene-section">
      <label>Dialogue Box</label>
      <div class="vn-dialog-setting">
        <span>Width</span>
        <input class="vn-dialog-width" type="range" min="30" max="100" step="1" value="{{dialog.width}}">
        <span class="vn-dialog-val">{{dialog.width}}%</span>
      </div>
      <div class="vn-dialog-setting">
        <span>Height</span>
        <input class="vn-dialog-height" type="range" min="80" max="350" step="5" value="{{dialog.height}}">
        <span class="vn-dialog-val">{{dialog.height}}px</span>
      </div>
      <div class="vn-dialog-setting">
        <span>Opacity</span>
        <input class="vn-dialog-opacity" type="range" min="0.2" max="1" step="0.05" value="{{dialog.opacity}}">
        <span class="vn-dialog-val">{{dialog.opacity}}</span>
      </div>
      <div class="vn-dialog-setting">
        <span>Align</span>
        <div class="vn-dialog-align-group">
          <button class="vn-dialog-align {{#if (eq dialog.align 'left')}}vn-align-active{{/if}}" data-align="left">Left</button>
          <button class="vn-dialog-align {{#if (eq dialog.align 'center')}}vn-align-active{{/if}}" data-align="center">Center</button>
          <button class="vn-dialog-align {{#if (eq dialog.align 'right')}}vn-align-active{{/if}}" data-align="right">Right</button>
        </div>
      </div>
      <div class="vn-dialog-setting">
        <span>Text</span>
        <textarea class="vn-dialog-text" rows="3" placeholder="Type dialogue here...">{{dialog.text}}</textarea>
      </div>
      <div class="vn-dialog-setting">
        <span>Speaker</span>
        <button class="vn-dialog-speaker-toggle">{{#if dialog.showSpeaker}}Show{{else}}Hide{{/if}}</button>
      </div>
      <div class="vn-dialog-setting">
        <span>Enable</span>
        <button class="vn-dialog-enable-toggle">{{#if dialogEnabled}}On{{else}}Off{{/if}}</button>
      </div>
      <div class="vn-dialog-setting">
        <span>Font size</span>
        <input class="vn-dialog-fontsize" type="range" min="10" max="36" step="1" value="{{dialog.fontSize}}">
        <span class="vn-dialog-val">{{dialog.fontSize}}px</span>
      </div>
    </div>
    <div class="vn-scene-section">
      <label>Speaker Box</label>
      <div class="vn-dialog-setting">
        <span>Font size</span>
        <input class="vn-speaker-fontsize" type="range" min="12" max="60" step="1" value="{{speakerFontSize}}">
        <span class="vn-dialog-val">{{speakerFontSize}}px</span>
      </div>
    </div>
    <div class="vn-scene-section">
      <label>Dialogue Mode</label>
      <div class="vn-dialog-setting">
        <span>Mode</span>
        <button class="vn-dialog-mode-toggle">{{#if (eq dialog.mode 2)}}Dual (2 boxes){{else}}Single + Speaker{{/if}}</button>
      </div>
      <div class="vn-dialog-setting">
        <span>Y Offset</span>
        <input class="vn-dialog-yoffset" type="range" min="20" max="300" step="5" value="{{dialog.yOffset}}">
        <span class="vn-dialog-val">{{dialog.yOffset}}px</span>
      </div>
      {{#if (eq dialog.mode 2)}}
      <div class="vn-dialog-setting">
        <span>Left Text</span>
        <textarea class="vn-dialog-lefttext" rows="3" placeholder="Type dialogue here...">{{dialog.leftText}}</textarea>
      </div>
      {{/if}}
    </div>
  </div>
  {{/if}}

  {{#if (eq showPanel "presets")}}
  <div class="vn-panel-floating">
    <div class="vn-panel-header">
      <span class="vn-panel-title">Scene Presets</span>
      <button class="vn-presets-back"><i class="fas fa-arrow-left"></i> Back</button>
    </div>
    <div class="vn-presets-save-row">
      <input class="vn-presets-name-input" type="text" placeholder="Preset name">
      <button class="vn-presets-save-btn">Save Current</button>
    </div>
    <div class="vn-presets-list">
      {{#each presets}}
      <div class="vn-presets-row">
        <span>{{this.name}}</span>
        <div class="vn-presets-actions">
          <button class="vn-presets-load" data-id="{{this.id}}">Load</button>
          <button class="vn-presets-delete" data-id="{{this.id}}"><i class="fas fa-trash"></i></button>
        </div>
      </div>
      {{/each}}
    </div>
  </div>
  {{/if}}
  </div>
  {{/if}}
</div>
